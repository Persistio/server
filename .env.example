# Database
DATABASE_URL=postgresql://mnemex:mnemex@postgres:5432/mnemex

# Server
PORT=4827
ADMIN_API_KEY=change-me-in-production

# Embedder — set EMBEDDER_PROVIDER to "openai" or "ollama"
EMBEDDER_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (only needed if EMBEDDER_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LLM Extractor (OpenAI-compatible endpoint)
EXTRACTOR_BASE_URL=https://api.openai.com/v1
EXTRACTOR_API_KEY=sk-...
EXTRACTOR_MODEL=gpt-4o-mini

# Extraction daemon
EXTRACTION_INTERVAL_MS=30000
EXTRACTION_BATCH_SIZE=20
MEMORY_ARCHIVE_TTL_DAYS=90

# Recall defaults (hint to clients)
DEFAULT_TOKEN_BUDGET=2000
DEFAULT_RECALL_TOP_K=10
